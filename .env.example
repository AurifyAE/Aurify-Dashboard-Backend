# Server
PORT=5000
NODE_ENV=development

# MongoDB (required for commodities and auth)
MONGO_URI=mongodb://localhost:27017/aurify

# JWT (required for /api/auth login and protected routes)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Next.js frontend screens base URL (used to build screen live links)
SCREEN_BASE_URL=http://localhost:3000
